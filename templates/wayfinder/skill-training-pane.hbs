<section class="skill-training-stage">
  <article class="skill-training-sheet" data-wayfinder-scroll-id="{{activePane.stepId}}:sheet">
    <header class="skill-training-header">
      <div>
        <p class="eyebrow">Class Training</p>
        <h4>{{activePane.className}}</h4>
        <p>{{activePane.description}}</p>
      </div>
      <div class="skill-training-status">
        <span class="skill-cap-label">Draft status</span>
        <strong>{{activePane.selectedLabel}}</strong>
      </div>
    </header>

    {{#if activePane.fixedSkills.length}}
      <section class="skill-training-block">
        <header class="skill-training-block-header">
          <p class="eyebrow">Automatic Training</p>
          <h5>Always trained</h5>
        </header>
        <div class="skill-training-fixed-list">
          {{#each activePane.fixedSkills}}
            <span class="fixed-skill-chip">{{this}}</span>
          {{/each}}
        </div>
      </section>
    {{/if}}

    {{#each activePane.choiceSections}}
      <section class="skill-training-block">
        <header class="skill-training-block-header">
          <div>
            <p class="eyebrow">Skill Choice</p>
            <h5>{{prompt}}</h5>
          </div>
          <span class="skill-training-source-label">{{sourceLabel}}</span>
        </header>
        <div class="skill-training-choice-list">
          {{#each options}}
            <button
              type="button"
              class="skill-training-choice{{#if selected}} selected{{/if}}"
              data-wayfinder-action="select-training-rule"
              data-step-id="{{../../activePane.stepId}}"
              data-key="{{../key}}"
              data-slug="{{slug}}"
              {{#if disabled}}disabled{{/if}}
            >
              <span class="skill-training-choice-copy">
                <span class="skill-training-choice-name">{{label}}</span>
                {{#if disabledReason}}
                  <span class="skill-increase-detail">{{disabledReason}}</span>
                {{/if}}
              </span>
              <span class="skill-training-choice-action">{{#if selected}}Chosen{{else}}Choose{{/if}}</span>
            </button>
          {{/each}}
        </div>
      </section>
    {{/each}}

    {{#if activePane.fixedLores.length}}
      <section class="skill-training-block">
        <header class="skill-training-block-header">
          <p class="eyebrow">Lore Training</p>
          <h5>Already granted lore</h5>
        </header>
        <div class="skill-training-fixed-list">
          {{#each activePane.fixedLores}}
            <span class="fixed-skill-chip lore-chip">{{this}}</span>
          {{/each}}
        </div>
      </section>
    {{/if}}

    {{#each activePane.loreSections}}
      <section class="skill-training-block">
        <header class="skill-training-block-header">
          <div>
            <p class="eyebrow">Lore Choice</p>
            <h5>{{prompt}}</h5>
          </div>
          <span class="skill-training-source-label">{{sourceLabel}}</span>
        </header>

        {{#if suggestions.length}}
          <div class="skill-training-choice-list lore-suggestion-list">
            {{#each suggestions}}
              <button
                type="button"
                class="skill-training-choice lore-suggestion{{#if selected}} selected{{/if}}"
                data-wayfinder-action="select-training-lore-suggestion"
                data-step-id="{{../../activePane.stepId}}"
                data-key="{{../key}}"
                data-value="{{value}}"
              >
                <span class="skill-training-choice-name">{{value}}</span>
                <span class="skill-training-choice-action">{{#if selected}}Chosen{{else}}Use{{/if}}</span>
              </button>
            {{/each}}
          </div>
        {{/if}}

        {{#if allowCustom}}
          <label class="skill-training-lore-field">
            <span class="skill-training-lore-label">Lore name</span>
            <input
              type="text"
              value="{{value}}"
              placeholder="{{placeholder}}"
              data-wayfinder-training-lore
              data-step-id="{{../activePane.stepId}}"
              data-key="{{key}}"
            />
          </label>
        {{/if}}
      </section>
    {{/each}}

    <section class="skill-training-block">
      <header class="skill-training-block-header">
        <div>
          <p class="eyebrow">Additional Skills</p>
          <h5>Choose {{activePane.additionalCount}} more skill{{#unless (eq activePane.additionalCount 1)}}s{{/unless}}</h5>
        </div>
        <span class="boost-remaining">{{activePane.additionalRemaining}} remaining</span>
      </header>
      <div class="skill-increase-list" data-wayfinder-scroll-id="{{activePane.stepId}}:skills">
        {{#each activePane.additionalSkills}}
          <button
            type="button"
            class="skill-increase-option{{#if selected}} selected{{/if}}"
            data-wayfinder-action="toggle-training-skill"
            data-step-id="{{../activePane.stepId}}"
            data-slug="{{slug}}"
            {{#if disabled}}disabled{{/if}}
          >
            <span class="skill-increase-ranks">
              <span class="rank-chip current rank-{{currentRankCode}}">{{currentRankCode}}</span>
              <i class="fa-solid fa-arrow-right-long rank-arrow"></i>
              <span class="rank-chip target rank-{{targetRankCode}}">{{targetRankCode}}</span>
            </span>
            <span class="skill-increase-copy">
              <span class="skill-increase-name">{{label}}</span>
              <span class="skill-increase-detail">
                {{#if disabledReason}}
                  {{disabledReason}}
                {{else}}
                  {{currentRankLabel}} to {{targetRankLabel}}
                {{/if}}
              </span>
            </span>
            <span class="skill-increase-action">
              {{#if selected}}Chosen{{else}}Choose{{/if}}
            </span>
          </button>
        {{/each}}
      </div>
    </section>
  </article>
</section>
