<section class="wayfinder-shell">
  {{#if hasPendingSteps}}
    <section class="wizard-frame">
      <aside class="wizard-rail">
        <header class="rail-header">
          <p class="eyebrow">Wayfinder</p>
          <h2 class="rail-actor-name">{{actorName}}</h2>
          <p class="rail-dossier-line">{{dossierLine}}</p>

          <div class="rail-status-row">
            <div class="level-card">
              <div class="level-badge">
                <span class="level-label">Cur</span>
                <strong>{{currentLevel}}</strong>
              </div>
              <div class="level-badge target">
                <span class="level-label">Tgt</span>
                <strong>{{targetLevel}}</strong>
              </div>
            </div>

            <div class="target-controls">
              <button type="button" class="icon" data-wayfinder-action="target-down" aria-label="Lower target level">
                <i class="fa-solid fa-minus"></i>
              </button>
              <button type="button" class="icon" data-wayfinder-action="target-up" aria-label="Raise target level">
                <i class="fa-solid fa-plus"></i>
              </button>
            </div>

            <div class="rail-progress">
              <div class="progress-dots">
                {{#each steps}}
                  <span class="progress-dot{{#if complete}} filled{{/if}}{{#if active}} active{{/if}}{{#if invalidated}} warn{{/if}}" title="{{title}}"></span>
                {{/each}}
              </div>
              <span class="progress-label">{{completedCount}}/{{stepCount}}</span>
            </div>
          </div>
        </header>

        <div class="wizard-step-list">
          {{#each steps}}
            {{#if firstInLevel}}
              <div class="step-level-divider">
                <span class="step-level-divider-label">Level {{level}}</span>
              </div>
            {{/if}}
            <button type="button" class="step-link{{#if active}} active{{/if}}{{#if complete}} complete{{/if}}{{#if invalidated}} invalidated{{/if}}" data-wayfinder-action="select-step" data-step-id="{{id}}">
              <span class="step-index">{{index}}</span>
              <span class="step-copy">
                <span class="step-title">{{title}}</span>
                <span class="step-status">{{status}}</span>
              </span>
            </button>
          {{/each}}
        </div>
      </aside>

      <main class="wizard-stage">
        {{#if activePane}}
          <header class="stage-bar">
            <div class="stage-bar-copy">
              <span class="stage-bar-step">Step {{activeStepIndex}}</span>
              <h3>{{activePane.title}}</h3>
              <span class="step-badge">Level {{activePane.level}} · {{activePane.modeLabel}}</span>
            </div>

            <div class="step-nav-controls">
              <button type="button" class="nav-btn" data-wayfinder-action="previous-step" {{#unless canGoPrevious}}disabled{{/unless}} aria-label="Previous step">
                <i class="fa-solid fa-chevron-left"></i>
              </button>
              <button type="button" class="nav-btn" data-wayfinder-action="next-step" {{#unless canGoNext}}disabled{{/unless}} aria-label="Next step">
                <i class="fa-solid fa-chevron-right"></i>
              </button>
            </div>
          </header>

          {{#if statusNote}}
            <div class="status-note">
              <i class="fa-solid fa-circle-info"></i>
              <span>{{statusNote}}</span>
            </div>
          {{/if}}

          {{#if activePane.isManual}}
            <section class="manual-pane">
              <article class="manual-sheet">
                <header class="manual-header">
                  <p class="eyebrow">Manual Checkpoint</p>
                  <h4>{{activePane.title}}</h4>
                  <p>{{activePane.description}}</p>
                </header>

                <div class="manual-body">
                  <div class="manual-status">
                    <span class="manual-label">Draft status</span>
                    <strong>{{activePane.selectedLabel}}</strong>
                  </div>

                  <label class="manual-check">
                    <input type="checkbox" data-wayfinder-manual data-step-id="{{activePane.stepId}}" {{#if activePane.completed}}checked{{/if}} />
                    <span>Mark this checkpoint complete once the PF2E sheet work is finished.</span>
                  </label>
                </div>
              </article>
            </section>
          {{/if}}

          {{#if activePane.isBoost}}
            <section class="boost-stage">
              {{#if activePane.blocked}}
                <div class="picker-state picker-state-blocked boost-blocked">
                  <p class="eyebrow">Prerequisite Required</p>
                  <h4>{{activePane.blockedTitle}}</h4>
                  <p>{{activePane.blockedMessage}}</p>
                </div>
              {{else}}
                <section class="boost-ledger">
                  <header class="boost-summary-header">
                    <p class="eyebrow">Projected Ability Modifiers</p>
                    <h4>{{activePane.selectedLabel}}</h4>
                  </header>

                  <div class="boost-ability-grid">
                    {{#each activePane.abilitySummary}}
                      <article class="boost-ability-card{{#if partial}} partial{{/if}}">
                        <span class="boost-ability-label">{{label}}</span>
                        <strong>{{modifierLabel}}</strong>
                        {{#if partial}}
                          <span class="boost-ability-note">Partial</span>
                        {{/if}}
                      </article>
                    {{/each}}
                  </div>
                </section>

                <section class="boost-sections">
                  {{#if activePane.ancestrySection}}
                    <article class="boost-sheet">
                      <header class="boost-section-header">
                        <div>
                          <p class="eyebrow">Ancestry</p>
                          <h4>Choose ancestry boosts</h4>
                        </div>
                        <div class="boost-section-tools">
                          <span class="boost-remaining">{{activePane.ancestrySection.remaining}} remaining</span>
                          {{#if activePane.ancestrySection.canToggleAlternate}}
                            <button type="button" class="secondary compact" data-wayfinder-action="toggle-ancestry-mode" data-step-id="{{activePane.stepId}}">
                              {{#if (eq activePane.ancestrySection.mode "alternate")}}Use printed boosts{{else}}Use alternate boosts{{/if}}
                            </button>
                          {{/if}}
                        </div>
                      </header>

                      <div class="boost-button-grid">
                        {{#each activePane.ancestrySection.buttons}}
                          <button type="button" class="boost-choice{{#if selected}} selected{{/if}}" data-wayfinder-action="toggle-boost-choice" data-step-id="{{../activePane.stepId}}" data-section="ancestry" data-attribute="{{attribute}}" {{#if disabled}}disabled{{/if}}>
                            <span class="boost-choice-code">{{attribute}}</span>
                            <span class="boost-choice-label">{{label}}</span>
                          </button>
                        {{/each}}
                      </div>
                    </article>
                  {{/if}}

                  {{#if activePane.voluntarySection}}
                    <article class="boost-sheet voluntary-sheet">
                      <header class="boost-section-header">
                        <div>
                          <p class="eyebrow">Optional</p>
                          <h4>Voluntary flaws</h4>
                        </div>
                        <div class="boost-section-tools voluntary-tools">
                          <button type="button" class="secondary compact" data-wayfinder-action="toggle-voluntary-enabled" data-step-id="{{activePane.stepId}}">
                            {{#if activePane.voluntarySection.enabled}}Disable{{else}}Enable{{/if}}
                          </button>
                          {{#if activePane.voluntarySection.enabled}}
                            <button type="button" class="secondary compact" data-wayfinder-action="toggle-voluntary-legacy" data-step-id="{{activePane.stepId}}">
                              {{#if activePane.voluntarySection.legacy}}Legacy rules on{{else}}Legacy rules off{{/if}}
                            </button>
                          {{/if}}
                        </div>
                      </header>

                      {{#if activePane.voluntarySection.enabled}}
                        <div class="voluntary-list">
                          {{#each activePane.voluntarySection.buttons}}
                            <div class="voluntary-row">
                              <span class="voluntary-label">{{label}}</span>
                              <div class="voluntary-actions">
                                <button type="button" class="secondary compact{{#if flawSelected}} is-selected{{/if}}" data-wayfinder-action="toggle-voluntary-choice" data-step-id="{{../activePane.stepId}}" data-attribute="{{attribute}}" data-choice-kind="flaw" {{#if flawDisabled}}disabled{{/if}}>Flaw</button>
                                {{#if showSecondFlaw}}
                                  <button type="button" class="secondary compact{{#if secondFlawSelected}} is-selected{{/if}}" data-wayfinder-action="toggle-voluntary-choice" data-step-id="{{../activePane.stepId}}" data-attribute="{{attribute}}" data-choice-kind="second-flaw" {{#if secondFlawDisabled}}disabled{{/if}}>Second flaw</button>
                                {{/if}}
                                {{#if showBoost}}
                                  <button type="button" class="secondary compact{{#if boostSelected}} is-selected{{/if}}" data-wayfinder-action="toggle-voluntary-choice" data-step-id="{{../activePane.stepId}}" data-attribute="{{attribute}}" data-choice-kind="boost" {{#if boostDisabled}}disabled{{/if}}>Boost</button>
                                {{/if}}
                              </div>
                            </div>
                          {{/each}}
                        </div>
                      {{/if}}
                    </article>
                  {{/if}}

                  {{#if activePane.backgroundSection}}
                    <article class="boost-sheet">
                      <header class="boost-section-header">
                        <div>
                          <p class="eyebrow">Background</p>
                          <h4>Choose background boosts</h4>
                        </div>
                        <span class="boost-remaining">{{activePane.backgroundSection.remaining}} remaining</span>
                      </header>

                      <div class="boost-button-grid">
                        {{#each activePane.backgroundSection.buttons}}
                          <button type="button" class="boost-choice{{#if selected}} selected{{/if}}" data-wayfinder-action="toggle-boost-choice" data-step-id="{{../activePane.stepId}}" data-section="background" data-attribute="{{attribute}}" {{#if disabled}}disabled{{/if}}>
                            <span class="boost-choice-code">{{attribute}}</span>
                            <span class="boost-choice-label">{{label}}</span>
                          </button>
                        {{/each}}
                      </div>
                    </article>
                  {{/if}}

                  {{#if activePane.classSection}}
                    <article class="boost-sheet">
                      <header class="boost-section-header">
                        <div>
                          <p class="eyebrow">Class</p>
                          <h4>Choose key ability</h4>
                        </div>
                      </header>

                      <div class="boost-button-grid">
                        {{#each activePane.classSection.options}}
                          <button type="button" class="boost-choice{{#if selected}} selected{{/if}}" data-wayfinder-action="toggle-boost-choice" data-step-id="{{../activePane.stepId}}" data-section="class" data-attribute="{{attribute}}">
                            <span class="boost-choice-code">{{attribute}}</span>
                            <span class="boost-choice-label">{{label}}</span>
                          </button>
                        {{/each}}
                      </div>
                    </article>
                  {{/if}}

                  <article class="boost-sheet">
                    <header class="boost-section-header">
                      <div>
                        <p class="eyebrow">Level {{activePane.levelSection.level}}</p>
                        <h4>Choose free boosts</h4>
                      </div>
                      <span class="boost-remaining">{{activePane.levelSection.remaining}} remaining</span>
                    </header>

                    <div class="boost-button-grid">
                      {{#each activePane.levelSection.buttons}}
                        <button type="button" class="boost-choice{{#if selected}} selected{{/if}}{{#if partial}} partial{{/if}}" data-wayfinder-action="toggle-boost-choice" data-step-id="{{../activePane.stepId}}" data-section="level-{{../activePane.levelSection.level}}" data-attribute="{{attribute}}" {{#if disabled}}disabled{{/if}}>
                          <span class="boost-choice-code">{{attribute}}</span>
                          <span class="boost-choice-label">{{label}}</span>
                        </button>
                      {{/each}}
                    </div>
                  </article>
                </section>
              {{/if}}
            </section>
          {{/if}}

          {{#if activePane.isPickItem}}
            <section class="selection-stage">
              <section class="option-browser">
                <header class="browser-header">
                  <div class="browser-header-row">
                    <h4>{{activePane.resultCount}} matching choice{{#unless (eq activePane.resultCount 1)}}s{{/unless}}</h4>
                    {{#if activePane.contextNote}}
                      <p class="context-note">{{activePane.contextNote}}</p>
                    {{/if}}
                  </div>

                  <label class="search-shell">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="search" value="{{activePane.search}}" placeholder="Search name, source, rarity…" data-wayfinder-search data-step-id="{{activePane.stepId}}" />
                  </label>
                </header>

                {{#if activePane.options.length}}
                  <div class="option-list" data-wayfinder-option-list data-step-id="{{activePane.stepId}}">
                    {{#each activePane.options}}
                      <article class="option-row{{#if previewing}} previewing{{/if}}{{#if selected}} selected{{/if}}">
                        <button type="button" class="option-main" data-wayfinder-action="preview-option" data-step-id="{{../activePane.stepId}}" data-value="{{value}}">
                          <img src="{{img}}" alt="{{name}}" />
                          <span class="option-copy">
                            <span class="option-title-row">
                              <span class="option-name">{{name}}</span>
                              {{#if rarity}}
                                <span class="option-rarity rarity-{{rarity}}">{{rarity}}</span>
                              {{/if}}
                            </span>
                            <span class="option-source">{{sourceLabel}}</span>
                          </span>
                        </button>

                        <button type="button" class="option-select{{#if selected}} is-selected{{/if}}" data-wayfinder-action="select-option" data-step-id="{{../activePane.stepId}}" data-value="{{value}}">
                          {{#if selected}}<i class="fa-solid fa-check"></i> Chosen{{else}}Choose{{/if}}
                        </button>
                      </article>
                    {{/each}}
                  </div>
                {{else}}
                  {{#if activePane.infoState}}
                    <div class="picker-state picker-state-{{activePane.infoState.tone}}">
                      <p class="eyebrow">{{activePane.infoState.eyebrow}}</p>
                      <h4>{{activePane.infoState.title}}</h4>
                      <p>{{activePane.infoState.message}}</p>
                    </div>
                  {{/if}}
                {{/if}}
              </section>

              <section class="preview-pane">
                {{#if activePane.preview}}
                  <header class="preview-banner">
                    <img src="{{activePane.preview.img}}" alt="{{activePane.preview.title}}" />

                    <div class="preview-heading">
                      <h4>{{activePane.preview.title}}</h4>
                      {{#if activePane.preview.source}}
                        <p class="preview-source">{{activePane.preview.source}}</p>
                      {{/if}}

                      <ul class="preview-tags">
                        {{#if activePane.preview.rarity}}
                          <li class="tag rarity-{{activePane.preview.rarity}}">{{activePane.preview.rarity}}</li>
                        {{/if}}
                        {{#each activePane.preview.tags}}
                          <li class="tag">{{this}}</li>
                        {{/each}}
                      </ul>
                    </div>

                    <div class="preview-actions">
                      <button type="button" class="primary" data-wayfinder-action="select-option" data-step-id="{{activePane.stepId}}" data-value="{{activePane.preview.value}}">
                        {{activePane.preview.selectedLabel}}
                      </button>
                      {{#if activePane.selectedValue}}
                        <button type="button" class="secondary" data-wayfinder-action="clear-option" data-step-id="{{activePane.slotId}}">
                          Clear
                        </button>
                      {{/if}}
                    </div>
                  </header>

                  {{#if activePane.preview.details.length}}
                    <dl class="detail-grid">
                      {{#each activePane.preview.details}}
                        <div class="detail-row">
                          <dt>{{label}}</dt>
                          <dd>{{value}}</dd>
                        </div>
                      {{/each}}
                    </dl>
                  {{/if}}

                  <section class="preview-description prose">
                    {{{activePane.preview.description}}}
                  </section>
                {{else}}
                  {{#if activePane.infoState}}
                    <div class="preview-empty picker-state picker-state-{{activePane.infoState.tone}}">
                      <p class="eyebrow">{{activePane.infoState.eyebrow}}</p>
                      <h4>{{activePane.infoState.title}}</h4>
                      <p>{{activePane.infoState.message}}</p>
                    </div>
                  {{else}}
                    <div class="preview-empty">
                      <p>Select an option to preview its details.</p>
                    </div>
                  {{/if}}
                {{/if}}
              </section>
            </section>
          {{/if}}
        {{/if}}
      </main>
    </section>
  {{else}}
    <section class="wayfinder-empty">
      <p>{{localize "PF2E-WAYFINDER.App.NoPending"}}</p>
    </section>
  {{/if}}

  <footer class="wayfinder-footer">
    <button type="button" class="footer-clear" data-wayfinder-action="clear-draft">Clear Draft</button>
    <div class="footer-actions">
      <button type="button" class="secondary" data-wayfinder-action="save-draft">Save Draft</button>
      <button type="button" class="primary" data-wayfinder-action="apply-draft">Apply Changes</button>
    </div>
  </footer>
</section>
