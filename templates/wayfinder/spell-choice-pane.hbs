<section class="selection-stage spell-selection-stage">
  <section class="option-browser">
    <header class="browser-header">
      <div class="browser-header-row spell-browser-header-row">
        <h4>{{activePane.selectedCount}} / {{activePane.requiredCount}} chosen</h4>
        <p class="context-note">{{activePane.destinationLabel}}</p>
      </div>

      <div class="spell-source-note">
        <span>Source: {{activePane.sourceName}}</span>
        {{#if activePane.contextNote}}
          <span>{{activePane.contextNote}}</span>
        {{/if}}
      </div>

      <label class="search-shell">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="search" value="{{activePane.search}}" placeholder="Search name, source, rarity…" data-wayfinder-search data-step-id="{{activePane.stepId}}" />
      </label>

      {{#if activePane.filterGroups.length}}
        <div class="picker-filter-bar">
          {{#each activePane.filterGroups}}
            <section class="picker-filter-menu{{#if isOpen}} is-open{{/if}}" data-wayfinder-filter-menu data-step-id="{{../activePane.stepId}}" data-filter-kind="{{key}}">
              <button type="button" class="picker-filter-trigger{{#if selectedCount}} is-active{{/if}}{{#if isOpen}} is-open{{/if}}" data-wayfinder-action="toggle-picker-filter-menu" data-step-id="{{../activePane.stepId}}" data-filter-kind="{{key}}" aria-expanded="{{#if isOpen}}true{{else}}false{{/if}}">
                <span class="picker-filter-trigger-copy">
                  <span class="picker-filter-label">{{label}}</span>
                  <span class="picker-filter-summary">{{summaryLabel}}</span>
                </span>

                <span class="picker-filter-trigger-meta">
                  {{#if selectedCount}}
                    <span class="picker-filter-badge">{{selectedCount}}</span>
                  {{/if}}
                  <i class="fa-solid fa-chevron-down"></i>
                </span>
              </button>

              {{#if isOpen}}
                <div class="picker-filter-panel">
                  <div class="picker-filter-panel-header">
                    <span class="picker-filter-panel-title">{{label}}</span>
                    <span class="picker-filter-panel-summary">{{summaryLabel}}</span>
                  </div>

                  <div class="picker-filter-options" data-wayfinder-scroll-id="{{../activePane.stepId}}:filter:{{key}}">
                    {{#each options}}
                      <button type="button" class="picker-filter-option{{#if selected}} is-selected{{/if}}" data-wayfinder-action="toggle-picker-filter" data-step-id="{{../../activePane.stepId}}" data-filter-kind="{{../key}}" data-value="{{value}}">
                        <span class="picker-filter-check">{{#if selected}}<i class="fa-solid fa-check"></i>{{/if}}</span>
                        <span class="picker-filter-option-label">{{label}}</span>
                        <span class="picker-filter-count">{{count}}</span>
                      </button>
                    {{/each}}
                  </div>
                </div>
              {{/if}}
            </section>
          {{/each}}

          {{#if activePane.activeFilterCount}}
            <button type="button" class="secondary compact picker-filter-clear" data-wayfinder-action="clear-picker-filters" data-step-id="{{activePane.stepId}}">
              Clear filters
            </button>
          {{/if}}
        </div>
      {{/if}}
    </header>

    {{#if activePane.options.length}}
      <div class="option-list" data-wayfinder-option-list data-step-id="{{activePane.stepId}}" data-wayfinder-scroll-id="{{activePane.stepId}}:options">
        {{#each activePane.options}}
          <article class="option-row{{#if previewing}} previewing{{/if}}{{#if selected}} selected{{/if}}">
            <button type="button" class="option-main" data-wayfinder-action="preview-option" data-step-id="{{../activePane.stepId}}" data-value="{{value}}">
              <img src="{{img}}" alt="{{name}}" />
              <span class="option-copy">
                <span class="option-title-row">
                  <span class="option-name">{{name}}</span>
                  {{#if rarity}}
                    <span class="option-rarity rarity-{{rarity}}">{{rarity}}</span>
                  {{/if}}
                </span>
                <span class="option-source">{{sourceLabel}}</span>
              </span>
            </button>

            <button type="button" class="option-select{{#if selected}} is-selected{{/if}}" data-wayfinder-action="toggle-spell-choice" data-step-id="{{../activePane.stepId}}" data-value="{{value}}">
              {{#if selected}}<i class="fa-solid fa-check"></i> Added{{else}}Add{{/if}}
            </button>
          </article>
        {{/each}}
      </div>
    {{else}}
      {{#if activePane.infoState}}
        <div class="picker-state picker-state-{{activePane.infoState.tone}}">
          <p class="eyebrow">{{activePane.infoState.eyebrow}}</p>
          <h4>{{activePane.infoState.title}}</h4>
          <p>{{activePane.infoState.message}}</p>
        </div>
      {{/if}}
    {{/if}}
  </section>

  <section class="preview-pane">
    {{#if activePane.preview}}
      <header class="preview-banner">
        <img src="{{activePane.preview.img}}" alt="{{activePane.preview.title}}" />

        <div class="preview-heading">
          <h4>{{activePane.preview.title}}</h4>
          {{#if activePane.preview.source}}
            <p class="preview-source">{{activePane.preview.source}}</p>
          {{/if}}

          <ul class="preview-tags">
            {{#if activePane.preview.rarity}}
              <li class="tag rarity-{{activePane.preview.rarity}}">{{activePane.preview.rarity}}</li>
            {{/if}}
            {{#each activePane.preview.tags}}
              <li class="tag">{{this}}</li>
            {{/each}}
          </ul>
        </div>

        <div class="preview-actions">
          <button type="button" class="primary" data-wayfinder-action="toggle-spell-choice" data-step-id="{{activePane.stepId}}" data-value="{{activePane.preview.value}}">
            {{activePane.preview.selectedLabel}}
          </button>
          {{#if activePane.selectedValues.length}}
            <button type="button" class="secondary" data-wayfinder-action="clear-option" data-step-id="{{activePane.slotId}}">
              Clear
            </button>
          {{/if}}
        </div>
      </header>

      {{#if activePane.preview.details.length}}
        <dl class="detail-grid">
          {{#each activePane.preview.details}}
            <div class="detail-row">
              <dt>{{label}}</dt>
              <dd title="{{value}}">{{value}}</dd>
            </div>
          {{/each}}
        </dl>
      {{/if}}

      <section class="preview-description prose">
        {{{activePane.preview.description}}}
      </section>
    {{else}}
      {{#if activePane.infoState}}
        <div class="preview-empty picker-state picker-state-{{activePane.infoState.tone}}">
          <p class="eyebrow">{{activePane.infoState.eyebrow}}</p>
          <h4>{{activePane.infoState.title}}</h4>
          <p>{{activePane.infoState.message}}</p>
        </div>
      {{else}}
        <div class="preview-empty">
          <p>Select a spell to preview it, then add it to the draft spellbook.</p>
        </div>
      {{/if}}
    {{/if}}
  </section>
</section>
