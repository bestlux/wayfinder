{
  "name": "pf2e-wayfinder",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "A guided PF2E creation and level-up workflow module for Foundry VTT.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "typecheck:strict": "tsc -p tsconfig.strict.json",
    "check:strict": "npm run typecheck:test && npm run typecheck:strict",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "npm run check && node tools/release/prepare-package.mjs",
    "package:artifact": "node tools/release/prepare-package.mjs",
    "audit:classes": "node tools/foundry-smoke/audit-class-coverage.mjs",
    "smoke:foundry": "node tools/foundry-smoke/run-foundry-smoke.mjs",
    "check": "npm run format:check && npm run lint && npm run build && npm test && npm run check:strict",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@eslint/js": "^10.0.1",
    "@types/node": "25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "playwright-core": "^1.59.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "4.1.3"
  }
}
