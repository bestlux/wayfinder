{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/actor-updater.ts",
    "src/actor-updater/**/*.ts",
    "src/shared/**/*.ts",
    "src/wayfinder/app-shell.ts",
    "src/wayfinder/application/**/*.ts",
    "src/wayfinder/domain/**/*.ts",
    "src/wayfinder/draft-decisions.ts",
    "src/wayfinder/invalidation.ts",
    "src/wayfinder/panes/boost-pane.ts",
    "src/wayfinder/slot-ids.ts",
    "tests/support/**/*.ts"
  ],
  "exclude": ["scripts", "node_modules"]
}
