<section class="skill-training-stage class-choice-stage">
  <article class="skill-training-sheet class-choice-sheet" data-wayfinder-scroll-id="{{activePane.stepId}}:sheet">
    <header class="skill-training-header">
      <div>
        <p class="eyebrow">Languages</p>
        <h4>{{activePane.selectedCount}} / {{activePane.requiredCount}} chosen</h4>
        <p>{{activePane.description}}</p>
      </div>
      <div class="skill-training-status">
        <span class="skill-cap-label">Draft status</span>
        <strong>{{activePane.selectedLabel}}</strong>
      </div>
    </header>

    <section class="skill-training-block">
      <header class="skill-training-block-header">
        <div>
          <p class="eyebrow">{{activePane.sourceName}}</p>
          <h5>Granted automatically</h5>
        </div>
      </header>

      {{#if activePane.grantedLanguages.length}}
        <div class="skill-training-choice-list class-choice-list">
          {{#each activePane.grantedLanguages}}
            <div class="skill-training-choice class-choice-option selected">
              <span class="class-choice-copy">
                <span class="skill-training-choice-name">{{this}}</span>
              </span>
              <span class="skill-training-choice-action">Granted</span>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="context-note">No granted base languages were detected for this source.</p>
      {{/if}}
    </section>

    <section class="skill-training-block">
      <header class="skill-training-block-header">
        <div>
          <p class="eyebrow">Choose additional languages</p>
          <h5>Available options</h5>
        </div>
      </header>

      <div class="skill-training-choice-list class-choice-list">
        {{#each activePane.options}}
          <button
            type="button"
            class="skill-training-choice class-choice-option{{#if selected}} selected{{/if}}"
            data-wayfinder-action="toggle-language-choice"
            data-step-id="{{@root.activePane.stepId}}"
            data-value="{{value}}"
          >
            <span class="class-choice-copy">
              <span class="skill-training-choice-name">{{label}}</span>
            </span>
            <span class="skill-training-choice-action">{{#if selected}}Chosen{{else}}Choose{{/if}}</span>
          </button>
        {{/each}}
      </div>
    </section>
  </article>
</section>
