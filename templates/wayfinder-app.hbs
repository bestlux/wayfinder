<section class="wayfinder-shell">
  {{#if hasPendingSteps}}
    <section class="wizard-frame">
      <aside class="wizard-rail">
        <header class="rail-header">
          <p class="eyebrow">Wayfinder</p>
          <h2 class="rail-actor-name">{{actorName}}</h2>
          <p class="rail-dossier-line">{{dossierLine}}</p>

          <div class="rail-status-row">
            <div class="level-card">
              <div class="level-badge">
                <span class="level-label">Cur</span>
                <strong>{{currentLevel}}</strong>
              </div>
              <div class="level-badge target">
                <span class="level-label">Tgt</span>
                <strong>{{targetLevel}}</strong>
              </div>
            </div>

            <div class="target-controls">
              <button type="button" class="icon" data-wayfinder-action="target-down" aria-label="Lower target level">
                <i class="fa-solid fa-minus"></i>
              </button>
              <button type="button" class="icon" data-wayfinder-action="target-up" aria-label="Raise target level">
                <i class="fa-solid fa-plus"></i>
              </button>
            </div>

            <div class="rail-progress">
              <div class="progress-dots">
                {{#each steps}}
                  <span class="progress-dot{{#if complete}} filled{{/if}}{{#if active}} active{{/if}}{{#if invalidated}} warn{{/if}}" title="{{title}}"></span>
                {{/each}}
              </div>
              <span class="progress-label">{{completedCount}}/{{stepCount}}</span>
            </div>
          </div>
        </header>

        <div class="wizard-step-list">
          {{#each steps}}
            {{#if firstInLevel}}
              <div class="step-level-divider">
                <span class="step-level-divider-label">Level {{level}}</span>
              </div>
            {{/if}}
            <button type="button" class="step-link{{#if active}} active{{/if}}{{#if complete}} complete{{/if}}{{#if invalidated}} invalidated{{/if}}" data-wayfinder-action="select-step" data-step-id="{{id}}">
              <span class="step-index">{{index}}</span>
              <span class="step-copy">
                <span class="step-title">{{title}}</span>
                <span class="step-status">{{status}}</span>
              </span>
            </button>
          {{/each}}
        </div>
      </aside>

      <main class="wizard-stage">
        {{#if activePane}}
          <header class="stage-bar">
            <div class="stage-bar-copy">
              <span class="stage-bar-step">Step {{activeStepIndex}}</span>
              <h3>{{activePane.title}}</h3>
              <span class="step-badge">Level {{activePane.level}} · {{activePane.modeLabel}}</span>
            </div>

            <div class="step-nav-controls">
              <button type="button" class="nav-btn" data-wayfinder-action="previous-step" {{#unless canGoPrevious}}disabled{{/unless}} aria-label="Previous step">
                <i class="fa-solid fa-chevron-left"></i>
              </button>
              <button type="button" class="nav-btn" data-wayfinder-action="next-step" {{#unless canGoNext}}disabled{{/unless}} aria-label="Next step">
                <i class="fa-solid fa-chevron-right"></i>
              </button>
            </div>
          </header>

          {{#if statusNote}}
            <div class="status-note">
              <i class="fa-solid fa-circle-info"></i>
              <span>{{statusNote}}</span>
            </div>
          {{/if}}

          {{#if activePane.isManual}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/manual-pane.hbs"}}
          {{/if}}

          {{#if activePane.isBoost}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/boost-pane.hbs"}}
          {{/if}}

          {{#if activePane.isSkillIncrease}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/skill-increase-pane.hbs"}}
          {{/if}}

          {{#if activePane.isSkillTraining}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/skill-training-pane.hbs"}}
          {{/if}}

          {{#if activePane.isClassChoice}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/class-choice-pane.hbs"}}
          {{/if}}

          {{#if activePane.isPickItem}}
            {{> "modules/pf2e-wayfinder/templates/wayfinder/pick-pane.hbs"}}
          {{/if}}
        {{/if}}
      </main>
    </section>
  {{else}}
    <section class="wayfinder-empty">
      <p>{{localize "PF2E-WAYFINDER.App.NoPending"}}</p>
    </section>
  {{/if}}

  <footer class="wayfinder-footer">
    <button type="button" class="footer-clear" data-wayfinder-action="clear-draft">Clear Draft</button>
    <div class="footer-actions">
      <button type="button" class="secondary" data-wayfinder-action="save-draft">Save Draft</button>
      <button type="button" class="primary" data-wayfinder-action="apply-draft">Apply Changes</button>
    </div>
  </footer>
</section>
